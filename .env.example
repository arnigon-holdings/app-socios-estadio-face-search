# AWS Rekognition + S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_S3_BUCKET_NAME=perfilamiento-faces
REKOGNITION_COLLECTION_ID=socios_stadium_users

# PostgreSQL (GCP Cloud SQL - for prod; for local use Docker host)
DATABASE_URL=postgres://app_perfil:dev_password@postgres:5432/app_perfil_development?sslmode=disable

# Service
PORT=8080

# Auth token shared with admin panel via VITE_FACE_SEARCH_TOKEN
FACE_SEARCH_TOKEN=dev-face-search-token

# CORS allowlist for browser calls from admin panel
CORS_ORIGINS=http://localhost:5174,http://localhost:5173
