# AWS Rekognition
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=perfilamiento-faces
REKOGNITION_COLLECTION_ID=socios_stadium_users

# PostgreSQL (GCP Cloud SQL - para testing local usar Cloud SQL Proxy)
DATABASE_URL=postgres://user:password@localhost:5432/perfilamiento

# Puerto
PORT=8080

# Auth token (compartido con admin panel)
FACE_SEARCH_TOKEN=dev-face-search-token

# CORS allowlist (comma-separated origins). Required for browser calls from admin panel.
# Add prod admin origin here when deploying.
CORS_ORIGINS=http://localhost:5174,http://localhost:5173
