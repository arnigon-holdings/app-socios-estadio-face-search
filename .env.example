# =============================================================================
# face-search-service/.env.example  —  Go service (búsqueda facial)
# =============================================================================
# Copiar a .env. docker-compose lo lee automáticamente desde backend/.env.aws
# (gitignored) o como variables de entorno del contenedor.
# NUNCA commitear el archivo .env real.
# =============================================================================

# ---- Server ----
PORT=8080

# ---- Postgres (DB del backend Rails) ----
DATABASE_URL=postgres://app_perfil:CHANGEME@localhost:5432/app_perfil_development?sslmode=disable

# ---- Auth ----
# Bearer token compartido con admin panel (Authorization: Bearer <token>).
FACE_SEARCH_TOKEN=                 # requerido; sin esto, todos los requests son 401

# ---- CORS ----
# CSV de origins permitidos. Sin esto = sin CORS = bloqueado por browser.
CORS_ORIGINS=http://localhost:5174

# ---- AWS ----
# En PRODUCCIÓN usar IAM role de Cloud Run (no requiere env vars).
# Solo dev requiere estas 3:
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- AWS S3 (presigned URLs para thumbnails de matches) ----
AWS_S3_BUCKET_NAME=perfilamiento-faces

# ---- AWS Rekognition ----
REKOGNITION_COLLECTION_ID=socios_stadium_users